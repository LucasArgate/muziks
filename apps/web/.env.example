# Copie para .env.local — espelhe apps/player/.env (mesmo Supabase + DATABASE_URL + Spotify)

NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# Player master (link "crie o seu player") — prod: https://player.muziks.app
# staging/develop: https://staging-player.muziks.app
NEXT_PUBLIC_PLAYER_APP_URL=http://127.0.0.1:3002
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transaction pooler URI (Supabase → Settings → Database)
DATABASE_URL=

NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Redirect URI no Spotify Dashboard (mesmo app do player):
# http://localhost:3000/api/auth/spotify/callback

# Opcional; se omitido, usa SUPABASE_SERVICE_ROLE_KEY
# SPOTIFY_TOKEN_ENCRYPTION_KEY=
