{
  "extends": "@muziks/config/tsconfig/base",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "trigger.config.ts"],
  "exclude": ["node_modules", "dist"]
}
