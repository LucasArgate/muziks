# Supabase (mesmo projeto que produção)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# API Keys → Secret keys (sb_secret_…) — não é o Client Secret do Spotify
SUPABASE_SERVICE_ROLE_KEY=

# Connect → Transaction pooler (ex.: aws-1-REGIAO.pooler.supabase.com:6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres

SPOTIFY_TOKEN_ENCRYPTION_KEY=

NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
# Uma linha só — copie do Spotify Dashboard (Settings → Client secret)
SPOTIFY_CLIENT_SECRET=

# Host = URL no browser + redirect no Spotify Dashboard (por ambiente na Vercel)
NEXT_PUBLIC_PLAYER_APP_URL=http://127.0.0.1:3002

# Origens extras para OAuth (staging, preview). Produção: https://staging-player.muziks.app
# PLAYER_ALLOWED_APP_ORIGINS=https://staging-player.muziks.app

# PLAYER_ALLOWED_DEV_ORIGINS=127.0.0.1,192.168.15.11

# Worker Supabase → Edge Function → POST /api/internal/playback-tick
PLAYBACK_WORKER_SECRET=
