# Supabase — use seu projeto (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# API Keys → Secret keys (sb_secret_…) — não é o Client Secret do Spotify
SUPABASE_SERVICE_ROLE_KEY=

# Connect → Transaction pooler (Dashboard → Database → URI, porta 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres

SPOTIFY_TOKEN_ENCRYPTION_KEY=

NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
# Uma linha só — copie do Spotify Dashboard (Settings → Client secret)
SPOTIFY_CLIENT_SECRET=

# URL pública do app neste ambiente (browser + redirect no Spotify Dashboard)
NEXT_PUBLIC_PLAYER_APP_URL=http://127.0.0.1:<port>

# Origens extras para OAuth (staging/preview), URLs completas separadas por vírgula
# PLAYER_ALLOWED_APP_ORIGINS=https://<staging-host>

# Hostnames extras em dev (sem porta) — ex.: celular na rede local
# PLAYER_ALLOWED_DEV_ORIGINS=127.0.0.1,<lan-ipv4>

# Worker Supabase → Edge Function → POST /api/internal/playback-tick
PLAYBACK_WORKER_SECRET=
