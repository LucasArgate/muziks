# Supabase — substitua pelos valores do seu projeto (Dashboard → Settings)
# SUPABASE_PROJECT_REF=<project-ref>
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Cliente (browser / PWA): publishable (recomendado) ou legacy anon JWT
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Servidor apenas (API Routes, Server Actions, migrations) — nunca NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle / psql (Transaction pooler)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres
