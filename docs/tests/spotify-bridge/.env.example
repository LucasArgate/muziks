# Copiar para docs/tests/spotify-bridge/.env antes de `docker compose up`
# Valores devem bater com apps/player/.env (mesmo PLAYBACK_WORKER_SECRET)

PORT=8765
HOST=0.0.0.0

# URL do apps/player acessível DE DENTRO do container bridge
# Linux: host.docker.internal ou IP da máquina
# Windows/Mac Docker Desktop: host.docker.internal
MUZIKS_PLAYER_API_URL=http://host.docker.internal:3002
PLAYBACK_WORKER_SECRET=coloque-o-mesmo-valor-do-player

SPOTIFY_CLIENT_ID=

LIBRESPOT_BIN=librespot
LIBRESPOT_PLAYER_NAME=Muziks Bridge Test
LIBRESPOT_CACHE_DIR=/app/cache
LIBRESPOT_AUTOSTART=false
