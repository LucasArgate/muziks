{
  "name": "muziks",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:landing": "turbo run dev --filter=@muziks/landing",
    "dev:web": "turbo run dev --filter=@muziks/web",
    "dev:player": "turbo run dev --filter=@muziks/player",
    "dev:spotify-bridge": "turbo run dev --filter=@muziks/spotify-bridge",
    "dev:playback-worker": "pnpm --filter @muziks/playback-worker dev",
    "deploy:playback-worker": "pnpm --filter @muziks/playback-worker run trigger:deploy",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @muziks/db db:generate",
    "db:migrate": "pnpm --filter @muziks/db db:migrate",
    "supabase": "pnpm dlx supabase@latest",
    "supabase:link": "pnpm dlx supabase@latest link --project-ref qgucuffklddzciejdtrb"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
